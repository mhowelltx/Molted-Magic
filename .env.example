# Names only — never fill in real values in this file. Real values go in a
# local, gitignored .env or GitHub Actions repo secrets, never committed.

# DigitalOcean API token (Personal Access Token, read+write)
DIGITALOCEAN_TOKEN=

# HCP Terraform (Terraform Cloud) auth. Org "FlyingThunderWolfDesign",
# workspace "molted-magic-openclaw" (execution mode: local — see
# openclaw/terraform/backend.tf). Terraform reads auth from an env var named
# exactly TF_TOKEN_<hostname-with-dots-as-underscores>.
TF_TOKEN_app_terraform_io=

# Public key content (not secret, but templated) — registered directly with
# DigitalOcean by Terraform (digitalocean_ssh_key.admin) and granted to the
# non-root admin user by cloud-init. Contents of a .pub file, e.g.
# "ssh-ed25519 AAAA... comment".
TF_VAR_admin_ssh_public_key=

# Matching private key for the deploy keypair (e.g. ~/.ssh/molted-magic-deploy)
# — used by provision.yml to SSH into the droplet after terraform apply and
# run install.sh/configure.sh. As a GitHub secret this is the raw private key
# file contents, not a path.
SSH_DEPLOY_PRIVATE_KEY=

# Tailscale auth key, if cloud-init joins the box to a tailnet. Leave unset to
# skip joining Tailscale (cloud-init handles an empty key gracefully).
TF_VAR_tailscale_authkey=

# Telegram bot token (from @BotFather), for the OpenClaw messaging channel
TELEGRAM_BOT_TOKEN=

# Separate, spend-capped Anthropic API key for the OpenClaw agent — never the
# main/personal Anthropic key
OPENCLAW_ANTHROPIC_KEY=
