# Names only — never fill in real values in this file. Real values go in a
# local, gitignored .env or GitHub Actions repo secrets, never committed.

# DigitalOcean API token (Personal Access Token, read+write)
DIGITALOCEAN_TOKEN=

# Terraform remote state backend — set whichever pair matches the chosen backend
# Option A: Terraform Cloud
TF_CLOUD_ORGANIZATION=
TF_WORKSPACE=
# Option B: DigitalOcean Spaces (S3-compatible)
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=

# SSH key (uploaded to DigitalOcean account) used to provision the droplet
TF_VAR_ssh_key_id=

# Tailscale auth key, if cloud-init joins the box to a tailnet
TAILSCALE_AUTHKEY=

# Telegram bot token (from @BotFather), for the OpenClaw messaging channel
TELEGRAM_BOT_TOKEN=

# Separate, spend-capped Anthropic API key for the OpenClaw agent — never the
# main/personal Anthropic key
OPENCLAW_ANTHROPIC_KEY=
