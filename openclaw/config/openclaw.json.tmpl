{
  "workspace": "${OPENCLAW_WORKSPACE_DIR}",
  "agents": [
    {
      "name": "openclaw",
      "model": "${OPENCLAW_MODEL}",
      "anthropic_api_key_env": "OPENCLAW_ANTHROPIC_KEY",
      "persona_file": "${OPENCLAW_CONFIG_DIR}/agent.md",
      "consent_mode": true,
      "tool_allowlist": [
        "web_search",
        "file_read",
        "file_write"
      ],
      "channels": {
        "telegram": {
          "bot_token_env": "TELEGRAM_BOT_TOKEN"
        }
      }
    }
  ]
}
